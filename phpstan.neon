includes:
    - vendor/larastan/larastan/extension.neon

parameters:

    paths:
        - src/
    level: 6
    treatPhpDocTypesAsCertain: false
    ignoreErrors:
        # JsonResource magic property access ($this->id, $this->name, etc.)
        -
            identifier: property.notFound
            path: src/Http/Resources/*


        # User model methods from HasTeams/HasApiTokens traits (applied by consumer)
        -
            identifier: method.notFound
            path: src/Http/Controllers/*
        -
            identifier: method.notFound
            path: src/Http/Resources/*
        -
            identifier: property.notFound
            path: src/Http/Controllers/*


        # Traits analysed in isolation — used by consumer's User model
        -
            identifier: trait.unused
            path: src/Traits/*

        # Fluent API returns new static() — intentional pattern
        -
            identifier: new.static
            path: src/MagicStarter.php

        # Action classes use Model/Authenticatable params — properties/methods resolved at runtime
        -
            identifier: property.notFound
            path: src/Actions/*
        -
            identifier: method.notFound
            path: src/Actions/*

        # Listener accesses Authenticatable properties ($id, $name) resolved at runtime
        -
            identifier: property.notFound
            path: src/Listeners/*


        # Eloquent generic type resolution (belongsTo, belongsToMany with dynamic models)
        -
            identifier: argument.templateType
            path: src/Models/*
        -
            identifier: return.type
            path: src/Models/*
        -
            identifier: missingType.generics
            path: src/Models/*
        -
            identifier: missingType.iterableValue
            path: src/Models/*

        # Socialite provider method (userFromToken exists at runtime)
        -
            message: '#Call to an undefined method Laravel\\Socialite\\Contracts\\Provider::userFromToken#'
            path: src/Http/Controllers/AuthController.php

        # Nullsafe on pivot role — defensive, not harmful
        -
            identifier: nullsafe.neverNull
            path: src/Http/Resources/*
