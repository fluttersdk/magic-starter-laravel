{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "fluttersdk/magic-starter-laravel",
    "description": "Magic Framework Laravel backend starter package.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "FlutterSdk",
            "email": "hello@fluttersdk.com"
        }
    ],
    "keywords": ["laravel", "auth", "teams", "profile", "starter", "sanctum", "jetstream"],
    "homepage": "https://magic.fluttersdk.com/starter",
    "support": {
        "docs": "https://magic.fluttersdk.com/packages/starter-laravel/getting-started/installation",
        "issues": "https://github.com/fluttersdk/magic-starter-laravel/issues",
        "source": "https://github.com/fluttersdk/magic-starter-laravel"
    },
    "require": {
        "php": "^8.2",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.0",
        "pragmarx/google2fa": "^8.0|^9.0",
        "bacon/bacon-qr-code": "^3.0"
    },
    "suggest": {
        "geoip2/geoip2": "Optional: for IP geolocation in session management"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.27",
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "FlutterSdk\\MagicStarter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FlutterSdk\\MagicStarter\\Tests\\": "tests/",
            "FlutterSdk\\MagicStarter\\Database\\Factories\\": "database/factories/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "FlutterSdk\\MagicStarter\\MagicStarterServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/pint --test",
        "lint:fix": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=1G"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
