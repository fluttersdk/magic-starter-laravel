{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_response.filePath // .tool_input.file_path' | grep '\\.php$' | xargs vendor/bin/pint 2>/dev/null || true",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
