{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | grep -E '\\.php$' | xargs -r vendor/bin/pint",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
